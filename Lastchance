from datetime import datetime, timedelta
import os
import requests

from airflow.sdk import DAG, task, BaseHook
from shared_tools.tools import default_args


timedeltas = {"j_7": 7, "j_30": 30}


def _is_composer() -> bool:
    return "COMPOSER_ENVIRONMENT" in os.environ


@task
def trigger_backfill(days: int, **context):
    # --- 1. Lecture de la Connection ---
    conn = BaseHook.get_connection("airflow_api")
    print(f"CONN: login={conn.login!r} pwd={conn.password!r} "
          f"host={conn.host!r} port={conn.port!r} "
          f"schema={conn.schema!r} type={conn.conn_type!r}")

    scheme = conn.schema or ("https" if _is_composer() else "http")
    base = f"{scheme}://{conn.host}"
    if conn.port:
        base += f":{conn.port}"
    print(f"BASE: {base}")

    # --- 2. Session sans héritage proxy ---
    session = requests.Session()
    session.trust_env = False

    # --- 3. Récupération du token ---
    if _is_composer():
        import google.auth
        from google.auth.transport.requests import Request
        creds, _ = google.auth.default(
            scopes=["https://www.googleapis.com/auth/cloud-platform"]
        )
        creds.refresh(Request())
        token = creds.token
        print(f"TOKEN (Composer): len={len(token)} starts={token[:20]}...")
    else:
        auth_req = requests.Request(
            "POST",
            f"{base}/auth/token",
            json={"username": conn.login, "password": conn.password},
        )
        auth_prepared = session.prepare_request(auth_req)
        print(f"AUTH REQ URL: {auth_prepared.url}")
        print(f"AUTH REQ HEADERS: {dict(auth_prepared.headers)}")
        print(f"AUTH REQ BODY: {auth_prepared.body!r}")

        ar = session.send(auth_prepared, timeout=30)
        print(f"AUTH RESP STATUS: {ar.status_code}")
        print(f"AUTH RESP BODY: {ar.text!r}")
        ar.raise_for_status()
        token = ar.json()["access_token"]
        print(f"TOKEN: len={len(token)} starts={token[:20]}...")

    # --- 4. Construction du payload ---
    ds = context["ds"]
    d = datetime.strptime(ds, "%Y-%m-%d")
    payload = {
        "dag_id": "etl_paid_media",
        "from_date": (d - timedelta(days=days + 1)).strftime("%Y-%m-%dT00:00:00Z"),
        "to_date":   (d - timedelta(days=days)).strftime("%Y-%m-%dT00:00:00Z"),
        "reprocess_behavior": "completed",
        "max_active_runs": 1,
        "run_backwards": False,
    }
    print(f"PAYLOAD: {payload}")

    # --- 5. Création du backfill ---
    bf_req = requests.Request(
        "POST",
        f"{base}/api/v2/backfills",
        headers={
            "Authorization": f"Bearer {token}",
            "Content-Type": "application/json",
        },
        json=payload,
    )
    bf_prepared = session.prepare_request(bf_req)
    print(f"BF REQ URL: {bf_prepared.url}")
    print(f"BF REQ HEADERS: {dict(bf_prepared.headers)}")
    print(f"BF REQ BODY: {bf_prepared.body!r}")

    br = session.send(bf_prepared, timeout=60)
    print(f"BF RESP STATUS: {br.status_code}")
    print(f"BF RESP BODY: {br.text!r}")
    br.raise_for_status()
    return br.json()


with DAG(
    "etl_paid_media_refresh",
    default_args=default_args,
    description="Data Refresh on day minus 8 each day -> Daily data not fully reliable on GCM",
    schedule=None,
    catchup=False,
) as dag:
    for delta_name, days in timedeltas.items():
        trigger_backfill.override(task_id=f"backfill_task_{delta_name}")(days=days)
