from datetime import datetime, timedelta
from urllib.parse import urlparse, unquote
import os
import requests

from airflow.sdk import DAG, task, BaseHook
from shared_tools.tools import default_args


timedeltas = {"j_7": 7, "j_30": 30}


def _is_composer() -> bool:
    return "COMPOSER_ENVIRONMENT" in os.environ


@task
def trigger_backfill(days: int, **context):
    # --- 1. Récupération du token + base URL ---
    if _is_composer():
        # Composer : Connection classique (host uniquement) + token GCP via SA
        conn = BaseHook.get_connection("airflow_api")
        scheme = conn.schema or "https"
        base = f"{scheme}://{conn.host}"
        if conn.port:
            base += f":{conn.port}"

        import google.auth
        from google.auth.transport.requests import Request
        creds, _ = google.auth.default(
            scopes=["https://www.googleapis.com/auth/cloud-platform"]
        )
        creds.refresh(Request())
        token = creds.token
    else:
        # Local : on parse l'URI brute pour échapper au secret masker d'Airflow
        uri = os.environ["AIRFLOW_CONN_AIRFLOW_API"]
        parsed = urlparse(uri)
        login = unquote(parsed.username or "")
        password = unquote(parsed.password or "")
        host = parsed.hostname
        port = parsed.port or 8080
        base = f"http://{host}:{port}"

        auth_session = requests.Session()
        auth_session.trust_env = False
        ar = auth_session.post(
            f"{base}/auth/token",
            json={"username": login, "password": password},
            timeout=30,
        )
        print(f"AUTH STATUS: {ar.status_code} BODY: {ar.text}")
        ar.raise_for_status()
        token = ar.json()["access_token"]

    # --- 2. Construction du payload ---
    ds = context["ds"]
    d = datetime.strptime(ds, "%Y-%m-%d")
    payload = {
        "dag_id": "etl_paid_media",
        "from_date": (d - timedelta(days=days + 1)).strftime("%Y-%m-%dT00:00:00Z"),
        "to_date":   (d - timedelta(days=days)).strftime("%Y-%m-%dT00:00:00Z"),
        "reprocess_behavior": "completed",
        "max_active_runs": 1,
        "run_backwards": False,
    }
    print(f"PAYLOAD: {payload}")

    # --- 3. Création du backfill ---
    session = requests.Session()
    session.trust_env = False
    br = session.post(
        f"{base}/api/v2/backfills",
        headers={
            "Authorization": f"Bearer {token}",
            "Content-Type": "application/json",
        },
        json=payload,
        timeout=60,
    )
    print(f"BF STATUS: {br.status_code} BODY: {br.text}")
    br.raise_for_status()
    return br.json()


with DAG(
    "etl_paid_media_refresh",
    default_args=default_args,
    description="Data Refresh on day minus 8 each day -> Daily data not fully reliable on GCM",
    schedule=None,
    catchup=False,
) as dag:
    for delta_name, days in timedeltas.items():
        trigger_backfill.override(task_id=f"backfill_task_{delta_name}")(days=days)
